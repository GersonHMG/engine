{
    "build": {
        "beforeDevCommand": "",
        "beforeBuildCommand": "npm run build",
        "devPath": "build",
        "distDir": "build",
        "withGlobalTauri": true
    },
    "package": {
        "productName": "engine",
        "version": "1.0.0"
    },
    "tauri": {
        "allowlist": {
            "all": false,
            "dialog": {
                "open": true
            },
            "shell": {
                "all": false,
                "open": true
            },
            "window": {
                "all": true
            }
        },
        "bundle": {
            "active": true,
            "targets": "all",
            "identifier": "com.sysmic.engine",
            "icon": [
                "icons/icon.ico"
            ]
        },
        "security": {
            "csp": null
        },
        "windows": [
            {
                "fullscreen": false,
                "resizable": true,
                "title": "Sysmic Engine",
                "width": 900,
                "height": 800,
                "decorations": false,
                "transparent": true
            }
        ]
    }
}